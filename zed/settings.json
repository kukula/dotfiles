{
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "prettier": {
    "allowed": true,
  },
  "document_symbols": "on",
  "document_folding_ranges": "on",
  "semantic_tokens": "combined",
  "base_keymap": "SublimeText",
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "agent": {
    "default_profile": "ask",
    "play_sound_when_agent_done": true,
    "dock": "right",
  },
  "icon_theme": "Zed (Default)",
  "edit_predictions": {
    "provider": "zed",
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 200,
  },
  "use_smartcase_search": true,
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "theme": "Ayu Dark",
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "!solargraph", "!steep", "!sorbet"],
      "formatter": "language_server",
      "format_on_save": "on",
      "tab_size": 2,
      "soft_wrap": "preferred_line_length",
    },
    "ERB": {
      "tab_size": 2,
      "format_on_save": "on",
    },
    "JSON": {
      "formatter": "prettier",
      "format_on_save": "on",
      "tab_size": 2,
    },
    "JSONC": {
      "formatter": "prettier",
      "format_on_save": "on",
      "tab_size": 2,
    },
    "YAML": {
      "formatter": "prettier",
      "format_on_save": "on",
      "tab_size": 2,
    },
    "Markdown": {
      "formatter": "prettier",
      "format_on_save": "on",
      "tab_size": 2,
      "soft_wrap": "editor_width",
      "remove_trailing_whitespace_on_save": false,
    },
  },
  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": true,
          "formatting": true,
          "codeActions": true,
          "hover": true,
          "completion": true,
          "documentSymbol": true,
          "workspaceSymbol": true,
          "semanticHighlighting": true,
        },
        "formatter": "auto",
      },
    },
  },
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "off",
  "current_line_highlight": "all",
  "max_tabs": 10,
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "centered_layout": {
    "left_padding": 0.2,
    "right_padding": 0.2,
  },
  "show_whitespaces": "selection",
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 2,
  },
  "scrollbar": {
    "show": "auto",
  },
  "cursor_blink": false,
  "show_wrap_guides": true,
  "wrap_guides": [80, 120],
  "preferred_line_length": 120,
  "auto_save": "on_focus_change",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "project_panel": {
    "dock": "left",
    "default_width": 240,
    "git_status": true,
  },
  "terminal": {
    "dock": "bottom",
    "default_height": 320,
    "font_size": 14,
    "working_directory": "current_project_directory",
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600,
    },
    "git_gutter": "tracked_files",
  },
  "file_types": {
    "Ruby": [
      "rb",
      "ruby",
      "rake",
      "gemspec",
      "Rakefile",
      "Gemfile",
      "Guardfile",
      "Capfile",
      "Vagrantfile",
      "Fastfile",
      "Appfile",
      "Deliverfile",
      "Matchfile",
      "Scanfile",
      "Snapfile",
      "Gymfile",
    ],
  },
}
